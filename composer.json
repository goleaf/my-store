{
    "name": "my-store/app",
    "type": "project",
    "description": "Laravel e-commerce store.",
    "keywords": [
        "ecommerce",
        "e-commerce",
        "livewire",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.0",
        "cartalyst/converter": "^9.0|^10",
        "doctrine/dbal": "^3.6",
        "filament/filament": "^5.0",
        "guzzlehttp/guzzle": "^7.2",
        "http-interop/http-factory-guzzle": "^1.2",
        "kalnoy/nestedset": "^v6.0.5",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.13.1",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.0",
        "livewire/livewire": "^4.0",
        "lukascivil/treewalker": "0.9.1",
        "meilisearch/meilisearch-php": "^1.6",
        "predis/predis": "^2.2",
        "spatie/laravel-activitylog": "^4.10.1",
        "spatie/laravel-blink": "^1.7.1",
        "spatie/laravel-medialibrary": "^11.12.7",
        "spatie/laravel-permission": "^6.12",
        "spatie/php-structure-discoverer": "^2.3.1",
        "stripe/stripe-php": "^16.0",
        "technikermathe/blade-lucide-icons": "^v3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "App\\Store\\Database\\Factories\\": "database/factories/",
            "App\\Store\\Database\\Seeders\\": "database/seeders/",
            "App\\Store\\Database\\State\\": "database/state/",
            "App\\Admin\\Database\\Factories\\": "database/factories/",
            "App\\Admin\\Database\\State\\": "database/state/",
            "App\\Shipping\\Database\\Factories\\": "database/factories/",
            "App\\Shipping\\Factories\\": "database/factories/"
        },
        "files": [
            "app/Store/helpers.php",
            "app/Admin/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}